# pixel_dream_agent Environment Variables

# === Project ===
PROJECT_NAME=pixel_dream_agent
DEBUG=true
ENVIRONMENT=local
TIMEZONE=UTC  # IANA timezone: UTC, Europe/Warsaw, America/New_York
MODELS_CACHE_DIR=./models_cache

# === Logfire ===
# Get your token at https://logfire.pydantic.dev
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=pixel_dream_agent
LOGFIRE_ENVIRONMENT=development

# === Server Ports (change per project to avoid conflicts) ===
BACKEND_PORT=8100
FRONTEND_PORT=3100
FLOWER_PORT=5556

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pixel_dream_agent

# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# === API Key Auth ===
API_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=
REDIS_DB=0

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0


# === AI Agent (langgraph, all) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=  # Moonshot AI (Kimi) — https://platform.moonshot.cn/console/api-keys
GROQ_API_KEY=      # Groq — https://console.groq.com/keys
# Ollama (local models) — set to your Ollama server URL
OLLAMA_URL=http://localhost:11434
# Multi-provider deployment — model name must include the provider prefix:
#   openai/<model>, anthropic/<model>, google/<model>, openrouter/<provider>/<model>
AI_MODEL=openai/gpt-5.5
AI_TEMPERATURE=0.7

# === Frontend ===
FRONTEND_URL=http://localhost:3100

# === LangSmith Observability ===
# Get your API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=pixel_dream_agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === CORS ===
# JSON list of allowed origins (default: localhost:3100, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3100","http://localhost:8080"]

# === Docker Production (Traefik) ===
# Domain for production deployment
DOMAIN=example.com

# Let's Encrypt email for SSL certificates
ACME_EMAIL=admin@example.com

# Traefik dashboard auth (generate with: htpasswd -nb admin password)
# TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...
# Redis password for production
REDIS_PASSWORD=change-me-in-production
# Flower monitoring credentials
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production
